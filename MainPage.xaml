<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SoFit.MainPage"
             BackgroundColor="Black">

    <Grid RowDefinitions="Auto,*,Auto" Padding="12">

        <!-- Header -->
        <Label Text="Home" FontSize="22" FontAttributes="Bold" TextColor="White" VerticalOptions="Start" />

        <!-- Main content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Padding="4">
                <Label Text="SoFit" FontSize="18" TextColor="White" />
                <Label Text="Welcome back" FontSize="14" TextColor="#CCCCCC" />

                <Frame BackgroundColor="#0a0a0a" Padding="12" CornerRadius="8" HasShadow="False">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Today's Goal: 750 / 1000 calories" TextColor="White" />
                    </VerticalStackLayout>
                </Frame>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                    <StackLayout Grid.Row="0" Grid.Column="0">
                        <Label Text="Calories" FontSize="12" TextColor="#999999" />
                        <Label Text="750" FontSize="16" TextColor="White" />
                    </StackLayout>

                    <StackLayout Grid.Row="0" Grid.Column="1">
                        <Label Text="Steps" FontSize="12" TextColor="#999999" />
                        <Label Text="8,432" FontSize="16" TextColor="White" />
                    </StackLayout>

                    <StackLayout Grid.Row="1" Grid.Column="0">
                        <Label Text="Heart Rate" FontSize="12" TextColor="#999999" />
                        <Label Text="72 bpm" FontSize="16" TextColor="White" />
                    </StackLayout>

                    <StackLayout Grid.Row="1" Grid.Column="1">
                        <Label Text="Workouts" FontSize="12" TextColor="#999999" />
                        <Label Text="3 this week" FontSize="16" TextColor="White" />
                    </StackLayout>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Action buttons -->
        <VerticalStackLayout Grid.Row="2" Spacing="8" Padding="0,8,0,0">
            <Button Text="Start Workout" BackgroundColor="#5B2DF1" TextColor="White" CornerRadius="8" HeightRequest="48" Clicked="OnStartWorkoutClicked" />
            <Button Text="Log Activity" BackgroundColor="#5B2DF1" TextColor="White" CornerRadius="8" HeightRequest="48" Clicked="OnLogActivityClicked" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
