<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SoFit.MainPage"
             BackgroundColor="#1a1a1a">

    <Grid RowDefinitions="*,70" RowSpacing="0" BackgroundColor="#1a1a1a">
        <!-- Main Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="20" BackgroundColor="#1a1a1a">

                <!-- Header -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="SoFit" FontSize="32" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Welcome back, Alex!" FontSize="16" TextColor="#999999" />
                </VerticalStackLayout>

                <!-- Today's Goal Card -->
                <Frame BorderColor="#0088cc" CornerRadius="20" Padding="20" HasShadow="True" BackgroundColor="#0a4d80">
                    <VerticalStackLayout Spacing="15">
                        <HorizontalStackLayout Spacing="15">
                            <Label Text="Today's Goal" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="FillAndExpand" />
                            <Button Text="🎯" FontSize="20" BackgroundColor="Transparent" Padding="0" Clicked="OnGoalDetailsClicked" />
                        </HorizontalStackLayout>

                        <Label Text="Progress" FontSize="14" TextColor="#cccccc" />
                        <ProgressBar Progress="0.75" ProgressColor="#00d4ff" BackgroundColor="#003d5c" HeightRequest="8" />
                        <Label Text="750 / 1000 calories burned" FontSize="12" TextColor="#999999" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Stats Grid -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="*,*" ColumnSpacing="15" RowSpacing="15">

                    <!-- Calories Card -->
                    <Frame Grid.Row="0" Grid.Column="0" BorderColor="#444" CornerRadius="15" Padding="15" HasShadow="False" BackgroundColor="#2a2a2a">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="🔥 Calories" FontSize="14" TextColor="#999999" />
                            <Label Text="750" FontSize="28" FontAttributes="Bold" TextColor="White" />
                            <Label Text="📈 +12% from yesterday" FontSize="11" TextColor="#00d4ff" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Steps Card -->
                    <Frame Grid.Row="0" Grid.Column="1" BorderColor="#444" CornerRadius="15" Padding="15" HasShadow="False" BackgroundColor="#2a2a2a">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="👟 Steps" FontSize="14" TextColor="#999999" />
                            <Label Text="8,432" FontSize="28" FontAttributes="Bold" TextColor="White" />
                            <Label Text="📈 +8% from yesterday" FontSize="11" TextColor="#00d4ff" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Heart Rate Card -->
                    <Frame Grid.Row="1" Grid.Column="0" BorderColor="#444" CornerRadius="15" Padding="15" HasShadow="False" BackgroundColor="#2a2a2a">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="❤️ Heart Rate" FontSize="14" TextColor="#999999" />
                            <Label Text="72" FontSize="28" FontAttributes="Bold" TextColor="White" />
                            <Label Text="BPM average" FontSize="11" TextColor="#999999" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Workouts Card -->
                    <Frame Grid.Row="1" Grid.Column="1" BorderColor="#444" CornerRadius="15" Padding="15" HasShadow="False" BackgroundColor="#2a2a2a">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="💪 Workouts" FontSize="14" TextColor="#999999" />
                            <Label Text="3" FontSize="28" FontAttributes="Bold" TextColor="White" />
                            <Label Text="This week" FontSize="11" TextColor="#999999" />
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <!-- Quick Actions -->
                <VerticalStackLayout Spacing="0">
                    <Label Text="Quick Actions" FontSize="18" FontAttributes="Bold" TextColor="White" />
                    <Button Text="Start Workout" BackgroundColor="#00d4ff" TextColor="Black" FontAttributes="Bold" CornerRadius="12" Padding="20" Margin="0,10,0,0" Clicked="OnStartWorkoutClicked" />
                    <Button Text="Log Activity" BackgroundColor="#333333" TextColor="White" FontAttributes="Bold" CornerRadius="12" Padding="20" Margin="0,10,0,0" Clicked="OnLogActivityClicked" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <HorizontalStackLayout Grid.Row="1" Spacing="0" BackgroundColor="#1a1a1a" Padding="0" >
            <Button x:Name="HomeBtn" Text="🏠 Home" HorizontalOptions="FillAndExpand" VerticalOptions="Fill" BackgroundColor="#0a4d80" TextColor="White" CornerRadius="0" Clicked="OnNavHomeClicked" />
            <Button x:Name="SplitBtn" Text="💪 Split" HorizontalOptions="FillAndExpand" VerticalOptions="Fill" BackgroundColor="Transparent" TextColor="#666666" CornerRadius="0" Clicked="OnNavSplitClicked" />
            <Button x:Name="BoardBtn" Text="📊 Board" HorizontalOptions="FillAndExpand" VerticalOptions="Fill" BackgroundColor="Transparent" TextColor="#666666" CornerRadius="0" Clicked="OnNavBoardClicked" />
            <Button x:Name="CalendarBtn" Text="📅 Calendar" HorizontalOptions="FillAndExpand" VerticalOptions="Fill" BackgroundColor="Transparent" TextColor="#666666" CornerRadius="0" Clicked="OnNavCalendarClicked" />
            <Button x:Name="SettingsBtn" Text="⚙️ Settings" HorizontalOptions="FillAndExpand" VerticalOptions="Fill" BackgroundColor="Transparent" TextColor="#666666" CornerRadius="0" Clicked="OnNavSettingsClicked" />
        </HorizontalStackLayout>
