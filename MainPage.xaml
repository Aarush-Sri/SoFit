<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SoFit.MainPage"
             Title="Home">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="SoFit" FontSize="24" HorizontalOptions="Center" />

            <!-- Today's Goal Card -->
            <Frame BorderColor="#0088cc" CornerRadius="8" Padding="12" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Today's Goal" FontSize="18" FontAttributes="Bold" />
                    <Label Text="Progress" FontSize="12" TextColor="Gray" />
                    <ProgressBar Progress="0.75" ProgressColor="#00d4ff" BackgroundColor="#eee" HeightRequest="8" />
                    <Label Text="750 / 1000 calories burned" FontSize="12" TextColor="Gray" />
                </VerticalStackLayout>
            </Frame>

            <!-- Stats Grid -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowSpacing="12">
                <Frame BorderColor="#ddd" CornerRadius="8" Padding="10" HasShadow="False">
                    <VerticalStackLayout>
                        <Label Text="🔥 Calories" FontSize="12" TextColor="Gray" />
                        <Label Text="750" FontSize="20" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Frame>

                <Frame BorderColor="#ddd" CornerRadius="8" Padding="10" HasShadow="False">
                    <VerticalStackLayout>
                        <Label Text="👟 Steps" FontSize="12" TextColor="Gray" />
                        <Label Text="8,432" FontSize="20" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Frame>

                <Frame BorderColor="#ddd" CornerRadius="8" Padding="10" HasShadow="False">
                    <VerticalStackLayout>
                        <Label Text="❤️ Heart Rate" FontSize="12" TextColor="Gray" />
                        <Label Text="72" FontSize="20" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Frame>

                <Frame BorderColor="#ddd" CornerRadius="8" Padding="10" HasShadow="False">
                    <VerticalStackLayout>
                        <Label Text="💪 Workouts" FontSize="12" TextColor="Gray" />
                        <Label Text="3" FontSize="20" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Quick Actions -->
            <VerticalStackLayout Spacing="8">
                <Button Text="Start Workout" Clicked="OnStartWorkoutClicked" />
                <Button Text="Log Activity" Clicked="OnLogActivityClicked" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
