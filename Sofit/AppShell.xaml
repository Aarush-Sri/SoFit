<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:Sofit.Views"
       x:Class="Sofit.AppShell">

    <TabBar>
        <Tab Title="Leaderboard">
            <ShellContent ContentTemplate="{DataTemplate views:LeaderboardPage}" />
        </Tab>
        <Tab Title="Social">
            <ShellContent ContentTemplate="{DataTemplate views:SocialPage}" />
        </Tab>
        <Tab Title="Split Schedule">
            <ShellContent ContentTemplate="{DataTemplate views:SplitSchedulePage}" />
        </Tab>
        <Tab Title="Calendar">
            <ShellContent ContentTemplate="{DataTemplate views:CalendarTrackerPage}" />
        </Tab>
    </TabBar>

</Shell>