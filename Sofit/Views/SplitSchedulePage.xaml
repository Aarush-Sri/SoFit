<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sofit.ViewModels"
             x:Class="Sofit.Views.SplitSchedulePage"
             Title="Split Schedule">
    <ContentPage.BindingContext>
        <vm:SplitScheduleViewModel />
    </ContentPage.BindingContext>

    <StackLayout Padding="20">
        <Label Text="Split Schedule" FontSize="24" HorizontalOptions="Center" />
        <CollectionView ItemsSource="{Binding Splits}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" Padding="10">
                        <StackLayout>
                            <Label Text="{Binding Name}" FontAttributes="Bold" />
                            <Label Text="{Binding Description}" />
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
</ContentPage>