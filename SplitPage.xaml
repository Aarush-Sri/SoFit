<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SoFit.SplitPage"
             Title="Split">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="Workout Splits" FontSize="24" HorizontalOptions="Center"/>

            <CollectionView x:Name="SplitsCollection" SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="8" Padding="12" Margin="0,6" HasShadow="True">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding Description}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Create Custom Split" Clicked="OnCreateCustomSplitClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
