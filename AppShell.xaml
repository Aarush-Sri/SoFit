<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SoFit.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SoFit"
    Title="SoFit">

  <TabBar>
    <ShellContent Title="Home" Route="home" ContentTemplate="{DataTemplate local:MainPage}" />
    <ShellContent Title="Split" Route="split" ContentTemplate="{DataTemplate local:SplitPage}" />
    <ShellContent Title="Board" Route="board" ContentTemplate="{DataTemplate local:BoardPage}" />
    <ShellContent Title="Calendar" Route="calendar" ContentTemplate="{DataTemplate local:CalendarPage}" />
    <ShellContent Title="Settings" Route="settings" ContentTemplate="{DataTemplate local:SettingsPage}" />
  </TabBar>

</Shell>
